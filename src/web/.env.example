# 1. Duplicate this file and rename it to .env
# 2. Fill in your own values for the variables below
AUTH_SECRET=
AUTH_GITHUB_ID=
AUTH_GITHUB_SECRET=
# Shared with the data layer for GitHub OAuth (POST /v1/create_or_login_user).
WEB_BRIDGE_SECRET=
RESEND_API_KEY=

# Public API URL (data layer). Required on self-hosted VPS when not using api.nextjudge.net.
# Baked in at `next build` — set this in your deploy/build environment (Coolify, docker build, etc.).
# Local `next dev` always uses http://localhost:5000 unless this points at another local port (e.g. E2E).
# Coolify PR previews: leave unset — the web app routes API calls to https://{PR}-api.preview.nextjudge.net at runtime.
NEXT_PUBLIC_API_URL=

DATABASE_URL=
